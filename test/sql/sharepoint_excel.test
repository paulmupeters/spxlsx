# name: test/sql/sharepoint_excel.test
# description: Test SharePoint Excel integration
# group: [sql]

require sharepoint

# Loading sharepoint should not require excel to already be installed on the system.
statement ok
LOAD sharepoint;

# Test that the download function is registered
query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE function_name = 'sharepoint_download_excel';
----
1

# Test that the macro is registered
query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE function_name = 'read_sharepoint_excel'
	AND macro_definition LIKE '%sharepoint_download_excel(url)%'
	AND macro_definition NOT LIKE '%duckdb_functions()%'
	AND list_contains(parameters, 'ignore_errors')
	AND list_contains(parameters, 'range')
	AND list_contains(parameters, 'stop_at_empty')
	AND list_contains(parameters, 'empty_as_varchar');
----
1

# Uncomment these tests when you have a real SharePoint Excel file to test with:
# require-env SHAREPOINT_TOKEN
# require-env SHAREPOINT_EXCEL_URL

# statement ok
# CREATE SECRET sharepoint_test (
#     TYPE sharepoint,
#     PROVIDER token,
#     TOKEN '${SHAREPOINT_TOKEN}'
# );

# Test downloading Excel file (returns a temp path)
# query I
# SELECT LENGTH(sharepoint_download_excel('${SHAREPOINT_EXCEL_URL}')) > 0;
# ----
# true

# Test reading Excel file via macro
# query I
# SELECT COUNT(*) >= 0
# FROM read_sharepoint_excel('${SHAREPOINT_EXCEL_URL}');
# ----
# true

# Test strict mode
# statement error
# SELECT COUNT(*)
# FROM read_sharepoint_excel('${SHAREPOINT_EXCEL_URL}', ignore_errors := false);

# Test reading specific sheet
# query I
# SELECT COUNT(*) >= 0
# FROM read_sharepoint_excel('${SHAREPOINT_EXCEL_URL}', sheet := 'Sheet1');
# ----
# true

# Test with range parameter
# query I
# SELECT COUNT(*) >= 0
# FROM read_sharepoint_excel('${SHAREPOINT_EXCEL_URL}', range := 'A1:E10');
# ----
# true

# Test preserving mixed types as text
# query I
# SELECT COUNT(*) >= 0
# FROM read_sharepoint_excel('${SHAREPOINT_EXCEL_URL}', all_varchar := true);
# ----
# true

# Clean up
# statement ok
# DROP SECRET sharepoint_test;
